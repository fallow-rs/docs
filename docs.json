{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "fallow",
  "colors": {
    "primary": "#1C1B1C",
    "light": "#8B7355",
    "dark": "#FDFAEF"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "background": {
    "decoration": "grid"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "index",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Analysis",
            "icon": "magnifying-glass",
            "pages": [
              "analysis/dead-code",
              "analysis/duplication",
              "analysis/auto-fix",
              "analysis/production-mode"
            ]
          },
          {
            "group": "Configuration",
            "icon": "gear",
            "pages": [
              "configuration/overview",
              "configuration/rules",
              "configuration/suppression"
            ]
          },
          {
            "group": "Frameworks",
            "icon": "puzzle-piece",
            "pages": [
              "frameworks/built-in",
              "frameworks/custom-plugins"
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "pages": [
              "integrations/ci",
              "integrations/vscode",
              "integrations/mcp"
            ]
          },
          {
            "group": "Migration",
            "icon": "right-left",
            "pages": [
              "migration/from-knip",
              "migration/from-jscpd"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "Commands",
            "icon": "terminal",
            "pages": [
              "cli/check",
              "cli/dupes",
              "cli/fix",
              "cli/watch",
              "cli/init",
              "cli/migrate",
              "cli/list"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/fallow-rs/fallow",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/fallow",
          "icon": "npm"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/fallow-rs/fallow"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/fallow-rs",
      "x": "https://x.com/AstroBartt"
    }
  },
  "feedback": {
    "enabled": true
  },
  "redirects": [
    { "source": "/ai-tools/claude-code", "destination": "/integrations/mcp" },
    { "source": "/ai-tools/cursor", "destination": "/integrations/mcp" },
    { "source": "/ai-tools/windsurf", "destination": "/integrations/mcp" },
    { "source": "/essentials/settings", "destination": "/configuration/overview" },
    { "source": "/essentials/navigation", "destination": "/configuration/overview" },
    { "source": "/essentials/markdown", "destination": "/quickstart" },
    { "source": "/essentials/code", "destination": "/quickstart" },
    { "source": "/api-reference/introduction", "destination": "/cli/check" },
    { "source": "/development", "destination": "/quickstart" }
  ],
  "seo": {
    "indexHiddenPages": false
  }
}
