{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "fallow",
  "colors": {
    "primary": "#1C1B1C",
    "light": "#8B7355",
    "dark": "#FDFAEF"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "css": "/custom.css",
  "favicon": "/favicon.svg",
  "background": {
    "decoration": "grid"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "index",
              "installation",
              "quickstart",
              "adoption"
            ]
          },
          {
            "group": "Analysis",
            "icon": "magnifying-glass",
            "pages": [
              "analysis/index",
              "analysis/dead-code",
              "analysis/duplication",
              "analysis/boundaries",
              "analysis/auto-fix",
              "analysis/runtime-coverage",
              "analysis/production-mode",
              "analysis/file-types",
              "analysis/css-analysis",
              "analysis/debugging",
              "analysis/limitations"
            ]
          },
          {
            "group": "Configuration",
            "icon": "gear",
            "pages": [
              "configuration/overview",
              "configuration/rules",
              "configuration/suppression",
              "configuration/workspaces",
              "configuration/boundaries",
              "configuration/environment"
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "pages": [
              "integrations/index",
              "integrations/mcp",
              "integrations/node-bindings",
              "integrations/agent-skills",
              "integrations/claude-hooks",
              "integrations/vscode",
              "integrations/ci",
              "integrations/badges"
            ]
          },
          {
            "group": "Explanations",
            "icon": "book-open",
            "pages": [
              "explanations/index",
              "explanations/static-vs-runtime",
              "explanations/fallow-vs-linters",
              "explanations/health",
              "explanations/duplication",
              "explanations/dead-code"
            ]
          },
          {
            "group": "Frameworks",
            "icon": "puzzle-piece",
            "pages": [
              "frameworks/built-in",
              "frameworks/custom-plugins"
            ]
          },
          {
            "group": "Migration",
            "icon": "right-left",
            "pages": [
              "migration/comparison",
              "migration/from-knip",
              "migration/from-jscpd"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "Commands",
            "icon": "terminal",
            "pages": [
              "cli/dead-code",
              "cli/dupes",
              "cli/health",
              "cli/license",
              "cli/coverage",
              "cli/flags",
              "cli/audit",
              "cli/explain",
              "cli/fix",
              "cli/watch",
              "cli/init",
              "cli/migrate",
              "cli/list",
              "cli/config",
              "cli/global-flags"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/fallow-rs/fallow",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/fallow",
          "icon": "npm"
        },
        {
          "anchor": "crates.io",
          "href": "https://crates.io/crates/fallow-cli",
          "icon": "rust"
        },
        {
          "anchor": "VS Code",
          "href": "https://marketplace.visualstudio.com/items?itemName=fallow-rs.fallow-vscode",
          "icon": "window"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/fallow-rs/fallow"
      },
      {
        "label": "Runtime",
        "href": "/explanations/static-vs-runtime"
      },
      {
        "label": "Pricing",
        "href": "https://fallow.tools/pricing"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/fallow-rs",
      "x": "https://x.com/BartWaardenburg"
    },
    "links": [
      {
        "header": "Resources",
        "items": [
          { "label": "Documentation", "href": "/" },
          { "label": "CLI Reference", "href": "/cli/dead-code" },
          { "label": "Configuration", "href": "/configuration/overview" },
          { "label": "Migration from knip", "href": "/migration/from-knip" }
        ]
      },
      {
        "header": "Community",
        "items": [
          { "label": "GitHub", "href": "https://github.com/fallow-rs/fallow" },
          { "label": "Issues", "href": "https://github.com/fallow-rs/fallow/issues" },
          { "label": "Discussions", "href": "https://github.com/fallow-rs/fallow/discussions" }
        ]
      },
      {
        "header": "Install",
        "items": [
          { "label": "npm", "href": "https://www.npmjs.com/package/fallow" },
          { "label": "crates.io", "href": "https://crates.io/crates/fallow-cli" },
          { "label": "VS Code Extension", "href": "https://marketplace.visualstudio.com/items?itemName=fallow-rs.fallow-vscode" }
        ]
      }
    ]
  },
  "feedback": {
    "enabled": true
  },
  "redirects": [
    { "source": "/ai-tools/claude-code", "destination": "/integrations/mcp" },
    { "source": "/ai-tools/cursor", "destination": "/integrations/mcp" },
    { "source": "/ai-tools/windsurf", "destination": "/integrations/mcp" },
    { "source": "/essentials/settings", "destination": "/configuration/overview" },
    { "source": "/essentials/navigation", "destination": "/configuration/overview" },
    { "source": "/essentials/markdown", "destination": "/quickstart" },
    { "source": "/essentials/code", "destination": "/quickstart" },
    { "source": "/api-reference/introduction", "destination": "/cli/dead-code" },
    { "source": "/cli/check", "destination": "/cli/dead-code" },
    { "source": "/development", "destination": "/quickstart" },
    { "source": "/explanations/metrics", "destination": "/explanations/health" }
  ],
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:title": "fallow: codebase intelligence for TypeScript and JavaScript",
      "og:description": "Two layers of intelligence for your codebase. Static (free): dead code, duplication, complexity, boundaries, feature flags. Runtime (optional): hot paths, cold paths, and deletion confidence backed by runtime coverage.",
      "og:image": "/images/icon.png",
      "og:site_name": "fallow",
      "twitter:card": "summary_large_image",
      "twitter:site": "@BartWaardenburg"
    }
  }
}
